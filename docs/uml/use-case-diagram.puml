@startuml
left to right direction
skinparam packageStyle rectangle

actor "Admin/Librarian" as Admin

rectangle "Smart Library System" {
  usecase "Create Account" as UC1
  usecase "Login" as UC2
  usecase "Logout" as UC3
  usecase "View Books" as UC4
  usecase "Add Book" as UC5
  usecase "Register Member" as UC6
  usecase "Issue Book" as UC7
  usecase "Return Book" as UC8
  usecase "View Logs" as UC9
}

Admin --> UC1
Admin --> UC2
Admin --> UC3
Admin --> UC4
Admin --> UC5
Admin --> UC6
Admin --> UC7
Admin --> UC8
Admin --> UC9

UC7 ..> UC4 : checks book availability
UC7 ..> UC6 : uses member ID
UC8 ..> UC9 : updates return status
@enduml
